APP_NAME="Silkpanel CMS"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL="https://silkpanel-cms.ddev.site"

# (edit able) Your Silkroad server database settings
# custom SilkPanel CMS env variables
SILKPANEL_API_KEY="55b463-5882c2-df5353-0ac173-576ed0-f9"
# vsro or isro
SILKPANEL_SERVER_VERSION=vsro


DB_SQL_HOST=127.1.2.3
DB_SQL_PORT=1433
DB_SQL_DATABASE_ACCOUNT=SRO_VT_ACCOUNT
DB_SQL_DATABASE_LOG=SRO_VT_SHARDLOG
DB_SQL_DATABASE_SHARD=SRO_VT_SHARD
DB_SQL_DATABASE_CUSTOM=DuckSoup_local
DB_SQL_DATABASE_PORTAL=GB_JoymaxPortal
DB_SQL_USERNAME=sa
DB_SQL_PASSWORD="<password>"
# (stop edit)

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION="mysql"
DB_HOST="db"
DB_PORT="3306"
DB_DATABASE="db"
DB_USERNAME="db"
DB_PASSWORD="db"

# Installer
INSTALLER_ENABLED=true

# change to database after installation
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=redis

# change to database after installation
CACHE_STORE=file
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

DB_TRUST_SERVER_CERTIFICATE=true
DB_ENCRYPT=true

# Donation / Payment Providers
DONATION_CURRENCY=USD

PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox
PAYPAL_WEBHOOK_ID=

STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

HIPOPAY_API_KEY=
HIPOPAY_API_SECRET=

HIPOCARD_API_KEY=
HIPOCARD_API_SECRET=
HIPOCARD_SILK_PER_UNIT=100

MAXICARD_USERNAME=
MAXICARD_PASSWORD=
MAXICARD_SILK_PER_UNIT=100

FAWATERK_API_KEY=your-api-key
FAWATERK_VENDOR_KEY=your-vendor-key
# or https://staging.fawaterk.com for tests
FAWATERK_ENDPOINT=https://app.fawaterk.com